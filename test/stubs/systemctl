#!/usr/bin/env bash
set -euo pipefail

if [[ ${1:-} == "--user" && ${2:-} == "show" ]]; then
  case "${STUB_SYSTEMCTL_MODE:-normal}" in
    normal) ;;
    fail)
      exit 1
      ;;
    empty)
      exit 0
      ;;
    partial)
      printf '%s\n' "${STUB_SYSTEMCTL_RESULT:-exit-code}"
      printf '%s\n' "${STUB_SYSTEMCTL_EXEC_CODE:-1}"
      exit 0
      ;;
  esac
  printf '%s\n' "${STUB_SYSTEMCTL_RESULT:-exit-code}"
  printf '%s\n' "${STUB_SYSTEMCTL_EXEC_CODE:-1}"
  printf '%s\n' "${STUB_SYSTEMCTL_EXEC_STATUS:-1}"
  printf '%s\n' "${STUB_SYSTEMCTL_EXEC_PID:-0}"
  exit 0
fi

if [[ ${1:-} == "--user" && ${2:-} == "reset-failed" ]]; then
  exit 0
fi

exit 0
